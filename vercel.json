{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/daily-update",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/weekly-digest",
      "schedule": "0 2 * * 1"
    }
  ]
}